# ========================================
# SeamXY Environment Configuration
# Copy this file to .env and fill in your values
# ========================================

# ========================================
# Application Environment
# ========================================
NODE_ENV=production
PORT=5000

# ========================================
# REQUIRED: PostgreSQL Database Configuration
# ========================================
# Full connection string format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@host:port/database

# Individual PostgreSQL connection parameters
PGHOST=your-db-host.com
PGPORT=5432
PGUSER=your-db-user
PGPASSWORD=your-db-password
PGDATABASE=seamxy_production

# ========================================
# REQUIRED: Security & Encryption
# ========================================
# Session secret for express-session (128 characters recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-128-char-session-secret-here

# Integration token encryption key (64 characters hex = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_TOKEN_KEY=your-64-char-encryption-key-here

# ========================================
# REQUIRED: AI Services
# ========================================
# IMPORTANT: Choose ONE option based on your deployment:

# Option 1: External Deployment (VPS, AWS, DigitalOcean, etc.)
# Use direct OpenAI API - Get key from https://platform.openai.com/
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Option 2: Replit Deployment
# Use Replit AI Integrations (automatically configured when deployed on Replit)
# Note: Replit AI Integrations ONLY work on Replit platform, not on external servers
# AI_INTEGRATIONS_OPENAI_BASE_URL=your-replit-ai-base-url
# AI_INTEGRATIONS_OPENAI_API_KEY=your-replit-ai-api-key

# ========================================
# OPTIONAL: Retailer APIs (Smart Price Compare Feature)
# ========================================
# Leave blank or comment out to disable specific retailers
# Price comparison will gracefully skip disabled retailers

# Amazon Product Advertising API (PAA5)
# Get credentials from: https://affiliate-program.amazon.com/assoc_credentials/home
# AMAZON_PARTNER_TAG=your-amazon-associate-tag-20
# AMAZON_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# AMAZON_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# eBay Browse API
# Get credentials from: https://developer.ebay.com/my/keys
# EBAY_CLIENT_ID=YourEbayClientId
# EBAY_CLIENT_SECRET=YourEbayClientSecret
# EBAY_PARTNER_NETWORK_ID=9

# Rakuten Advertising API
# Get credentials from: https://developers.rakutenadvertising.com/
# RAKUTEN_API_KEY=your-rakuten-application-id
# RAKUTEN_AFFILIATE_ID=your-rakuten-affiliate-id

# ========================================
# OPTIONAL: E-commerce Platform OAuth (Supplier Portal)
# ========================================
# Only needed if suppliers will connect their Shopify/WooCommerce/BigCommerce stores

# Shopify App Credentials
# Create app at: https://partners.shopify.com/
# SHOPIFY_CLIENT_ID=your-shopify-client-id
# SHOPIFY_CLIENT_SECRET=your-shopify-client-secret

# WooCommerce REST API
# Note: Each supplier will provide their own consumer key/secret
# These are example format only - actual credentials are per-store
# WOOCOMMERCE_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# BigCommerce App Credentials
# Create app at: https://devtools.bigcommerce.com/my/apps
# BIGCOMMERCE_CLIENT_ID=your-bigcommerce-client-id
# BIGCOMMERCE_CLIENT_SECRET=your-bigcommerce-client-secret

# ========================================
# Development Notes
# ========================================
# - SESSION_SECRET: Used to sign session cookies. Must be strong and unique per environment.
# - INTEGRATION_TOKEN_KEY: Used for AES-256-CBC encryption of OAuth tokens. Must be exactly 64 hex characters (32 bytes).
# - AI credentials: Required for AI stylist personas and style analysis features.
# - Retailer APIs: Optional - system degrades gracefully if not provided.
# - E-commerce OAuth: Optional - only needed if supplier portal is used.
# - Never commit .env file to version control!
# - Use different values for development, staging, and production environments.
